# WHOOP API (OAuth 2.0)
# Register your app at https://developer.whoop.com/
# Privacy policy: https://www.edward-lai.com/whoop-debrief/privacy
# Redirect URL in dashboard must match WHOOP_REDIRECT_URI below exactly
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8080/callback

# Tokens (written by scripts/auth.py after OAuth flow)
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Google Cloud / BigQuery
# Paste full service account JSON as a single line (for GitHub Actions)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Or point to local key file for dev
GOOGLE_APPLICATION_CREDENTIALS=gcp/service_account.json

BQ_PROJECT=
BQ_DATASET_RAW=whoop_raw
BQ_DATASET_DBT=whoop_dbt
BQ_LOCATION=us-central1
